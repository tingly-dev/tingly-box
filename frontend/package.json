{
  "name": "tingly-box",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development --port 9245",
    "dev:mock": "vite --mode mock",
    "dev:real": "vite --mode production",
    "build:dev": "vite build --minify false --mode development",
    "build:dev:wails": "vite build --minify false --mode development-wails --config vite.config.wails.ts",
    "build:dev:wails:lite": "vite build --minify false --mode development-wails-lite --config vite.config.wails.ts",
    "build": "vite build --mode production",
    "build:wails": "vite build --mode production-wails --config vite.config.wails.ts",
    "build:wails:lite": "vite build --mode production-wails-lite --config vite.config.wails.ts",
    "preview": "vite preview",
    "gen:api": "openapi-typescript ../openapi.json -o ./src/client/schema.d.ts",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/x-markdown": "^2.7.0",
    "@lobehub/icons-static-svg": "^1.90.0",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/x-date-pickers": "^8.28.5",
    "@tabler/icons": "^3.44.0",
    "@tabler/icons-react": "^3.44.0",
    "@types/react": "^19.2.14",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "devicons-react": "^1.5.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "openai": "^6.37.0",
    "openapi-fetch": "^0.17.0",
    "prism-react-renderer": "^2.4.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.15.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "upath": "^2.0.1",
    "uuid": "^13.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.64.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "8.0.5"
  },
  "overrides": {
    "d3-array": "^3.2.4",
    "d3-contour": "^4.0.2"
  },
  "optionalDependencies": {
    "@wailsio/runtime": "3.0.0-alpha.79"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}