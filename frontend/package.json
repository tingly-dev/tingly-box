{
  "name": "tingly-box",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development --port 9245",
    "dev:mock": "USE_MOCK=true vite --mode mock",
    "dev:real": "vite --mode production",
    "build:dev": "vite build --minify false --mode development",
    "build:dev:wails": "vite build --minify false --mode development-wails --config vite.config.wails.ts",
    "build:dev:wails:lite": "vite build --minify false --mode development-wails-lite --config vite.config.wails.ts",
    "build": "vite build --mode production",
    "build:wails": "vite build --mode production-wails --config vite.config.wails.ts",
    "build:wails:lite": "vite build --mode production-wails-lite --config vite.config.wails.ts",
    "preview": "vite preview",
    "gen:api": "openapi-typescript ../openapi.json -o ./src/client/schema.d.ts",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/x-markdown": "^2.8.0",
    "@lobehub/icons-static-svg": "^1.94.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-date-pickers": "^9.10.0",
    "@tabler/icons": "^3.45.0",
    "@tabler/icons-react": "^3.45.0",
    "@types/react": "^19.2.17",
    "@types/react-transition-group": "^4.4.12",
    "date-fns": "^4.4.0",
    "devicons-react": "^1.5.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "openai": "^6.48.0",
    "openapi-fetch": "^0.17.0",
    "prism-react-renderer": "^2.4.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.18.1",
    "react-transition-group": "^4.4.5",
    "recharts": "^3.9.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.74.0",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.5"
  },
  "overrides": {
    "d3-array": "^3.2.4",
    "d3-contour": "^4.0.2"
  },
  "optionalDependencies": {
    "@wailsio/runtime": "3.0.0-alpha.79"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}