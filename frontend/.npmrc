# Disable pnpm's supply-chain minimumReleaseAge policy.
# CI runs pnpm@latest via corepack, whose recent versions enable this policy by
# default and reject dependencies published within the cooldown window. Our
# dependency update flow does not enforce that cooldown, so disable it here to
# keep `pnpm install --frozen-lockfile` consistent with the committed lockfile.
minimumReleaseAge=0