{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/schemas/claude-code-stream-json.schema.json",
  "title": "Claude Code / Claude Agent SDK stream-json message",
  "description": "Schema for a single NDJSON line emitted by `claude --print --output-format stream-json --verbose`. Each line is one object matching one of the variants below, discriminated by `type`. Not an official Anthropic-published artifact — compiled from the Agent SDK TypeScript (sdk.d.ts) / Python (types.py) type definitions and the public Agent SDK docs (code.claude.com/docs/en/agent-sdk).",
  "oneOf": [
    { "$ref": "#/definitions/SDKSystemMessage" },
    { "$ref": "#/definitions/SDKAssistantMessage" },
    { "$ref": "#/definitions/SDKUserMessage" },
    { "$ref": "#/definitions/SDKResultMessage" },
    { "$ref": "#/definitions/SDKPartialAssistantMessage" }
  ],
  "definitions": {
    "UUID": {
      "type": "string",
      "format": "uuid"
    },
    "MCPServerStatus": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["connected", "failed", "needs-auth", "pending"] }
      },
      "required": ["name", "status"]
    },
    "Usage": {
      "type": "object",
      "description": "Token usage, mirrors the Anthropic Messages API Usage object.",
      "properties": {
        "input_tokens": { "type": "integer" },
        "output_tokens": { "type": "integer" },
        "cache_creation_input_tokens": { "type": ["integer", "null"] },
        "cache_read_input_tokens": { "type": ["integer", "null"] },
        "cache_creation": {
          "type": ["object", "null"],
          "properties": {
            "ephemeral_5m_input_tokens": { "type": "integer" },
            "ephemeral_1h_input_tokens": { "type": "integer" }
          }
        },
        "server_tool_use": {
          "type": ["object", "null"],
          "properties": {
            "web_search_requests": { "type": "integer" },
            "web_fetch_requests": { "type": "integer" }
          }
        },
        "service_tier": { "type": ["string", "null"] }
      },
      "required": ["input_tokens", "output_tokens"]
    },
    "TextBlock": {
      "type": "object",
      "properties": {
        "type": { "const": "text" },
        "text": { "type": "string" }
      },
      "required": ["type", "text"]
    },
    "ToolUseBlock": {
      "type": "object",
      "properties": {
        "type": { "const": "tool_use" },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "input": { "type": "object" }
      },
      "required": ["type", "id", "name", "input"]
    },
    "ThinkingBlock": {
      "type": "object",
      "properties": {
        "type": { "const": "thinking" },
        "thinking": { "type": "string" },
        "signature": { "type": "string" }
      },
      "required": ["type", "thinking"]
    },
    "ToolResultBlock": {
      "type": "object",
      "properties": {
        "type": { "const": "tool_result" },
        "tool_use_id": { "type": "string" },
        "content": {
          "oneOf": [
            { "type": "string" },
            { "type": "array" }
          ]
        },
        "is_error": { "type": "boolean" }
      },
      "required": ["type", "tool_use_id", "content"]
    },

    "SDKSystemMessage": {
      "type": "object",
      "description": "Emitted once at session start (subtype: init). May also appear mid-stream with subtype 'compact_boundary'.",
      "properties": {
        "type": { "const": "system" },
        "subtype": { "type": "string", "enum": ["init", "compact_boundary"] },
        "uuid": { "$ref": "#/definitions/UUID" },
        "session_id": { "type": "string" },
        "cwd": { "type": "string" },
        "model": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "mcp_servers": { "type": "array", "items": { "$ref": "#/definitions/MCPServerStatus" } },
        "permissionMode": {
          "type": "string",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"]
        },
        "apiKeySource": {
          "type": "string",
          "enum": ["ANTHROPIC_API_KEY", "none", "config"]
        },
        "slash_commands": { "type": "array", "items": { "type": "string" } },
        "agents": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "array", "items": {} },
        "plugins": { "type": "array", "items": { "type": "object" } },
        "output_style": { "type": "string" },
        "claude_code_version": { "type": "string" }
      },
      "required": ["type", "subtype", "session_id"]
    },

    "SDKAssistantMessage": {
      "type": "object",
      "description": "A complete assistant turn (may contain text and/or tool_use blocks).",
      "properties": {
        "type": { "const": "assistant" },
        "uuid": { "$ref": "#/definitions/UUID" },
        "session_id": { "type": "string" },
        "parent_tool_use_id": { "type": ["string", "null"] },
        "message": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "message" },
            "role": { "const": "assistant" },
            "model": { "type": "string" },
            "content": {
              "type": "array",
              "items": {
                "oneOf": [
                  { "$ref": "#/definitions/TextBlock" },
                  { "$ref": "#/definitions/ToolUseBlock" },
                  { "$ref": "#/definitions/ThinkingBlock" }
                ]
              }
            },
            "stop_reason": {
              "type": ["string", "null"],
              "enum": ["end_turn", "max_tokens", "stop_sequence", "tool_use", "pause_turn", "refusal", null]
            },
            "stop_sequence": { "type": ["string", "null"] },
            "usage": { "$ref": "#/definitions/Usage" },
            "context_management": {}
          },
          "required": ["role", "content"]
        }
      },
      "required": ["type", "session_id", "message"]
    },

    "SDKUserMessage": {
      "type": "object",
      "description": "Tool results (and, in stdin/stream-json input mode, user turns) sent back into the conversation.",
      "properties": {
        "type": { "const": "user" },
        "uuid": { "$ref": "#/definitions/UUID" },
        "session_id": { "type": "string" },
        "parent_tool_use_id": { "type": ["string", "null"] },
        "message": {
          "type": "object",
          "properties": {
            "role": { "const": "user" },
            "content": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "$ref": "#/definitions/ToolResultBlock" },
                      { "$ref": "#/definitions/TextBlock" }
                    ]
                  }
                }
              ]
            }
          },
          "required": ["role", "content"]
        },
        "tool_use_result": {
          "description": "SDK-attached structured summary of the tool result (shape is tool-specific, e.g. Glob returns filenames/durationMs/numFiles/truncated).",
          "type": "object"
        }
      },
      "required": ["type", "session_id", "message"]
    },

    "SDKResultMessage": {
      "type": "object",
      "description": "Final message indicating query completion.",
      "properties": {
        "type": { "const": "result" },
        "subtype": {
          "type": "string",
          "enum": ["success", "error_max_turns", "error_max_budget_usd", "error_during_execution"]
        },
        "uuid": { "$ref": "#/definitions/UUID" },
        "session_id": { "type": "string" },
        "is_error": { "type": "boolean" },
        "duration_ms": { "type": "integer" },
        "duration_api_ms": { "type": "integer" },
        "num_turns": { "type": "integer" },
        "result": { "type": ["string", "null"] },
        "total_cost_usd": { "type": "number" },
        "usage": { "$ref": "#/definitions/Usage" },
        "modelUsage": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "inputTokens": { "type": "integer" },
              "outputTokens": { "type": "integer" },
              "cacheReadInputTokens": { "type": "integer" },
              "cacheCreationInputTokens": { "type": "integer" },
              "webSearchRequests": { "type": "integer" },
              "costUSD": { "type": "number" },
              "contextWindow": { "type": "integer" },
              "maxOutputTokens": { "type": "integer" }
            }
          }
        },
        "permission_denials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tool_name": { "type": "string" },
              "tool_use_id": { "type": "string" },
              "tool_input": { "type": "object" }
            }
          }
        },
        "structured_output": {
          "description": "Present only when --json-schema / a structured output format was requested; validated JSON matching that schema."
        },
        "errors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "subtype", "session_id", "is_error"]
    },

    "SDKPartialAssistantMessage": {
      "type": "object",
      "description": "Raw Claude API streaming event, emitted only when --include-partial-messages / include_partial_messages is set.",
      "properties": {
        "type": { "const": "stream_event" },
        "uuid": { "$ref": "#/definitions/UUID" },
        "session_id": { "type": "string" },
        "parent_tool_use_id": { "type": "null" },
        "ttft_ms": { "type": "integer", "description": "Time to first token in ms; present only on message_start events." },
        "event": {
          "type": "object",
          "description": "Raw Anthropic Messages API stream event (message_start | content_block_start | content_block_delta | content_block_stop | message_delta | message_stop). See platform.claude.com/docs/en/build-with-claude/streaming for the full event schema.",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "message_start",
                "content_block_start",
                "content_block_delta",
                "content_block_stop",
                "message_delta",
                "message_stop"
              ]
            },
            "index": { "type": "integer" },
            "message": { "type": "object" },
            "content_block": {
              "oneOf": [
                { "$ref": "#/definitions/TextBlock" },
                { "$ref": "#/definitions/ToolUseBlock" },
                { "$ref": "#/definitions/ThinkingBlock" }
              ]
            },
            "delta": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["text_delta", "input_json_delta", "thinking_delta", "signature_delta", "citations_delta"]
                },
                "text": { "type": "string" },
                "partial_json": { "type": "string" },
                "thinking": { "type": "string" },
                "stop_reason": { "type": ["string", "null"] },
                "stop_sequence": { "type": ["string", "null"] }
              }
            },
            "usage": { "type": "object" }
          },
          "required": ["type"]
        }
      },
      "required": ["type", "session_id", "event"]
    }
  }
}